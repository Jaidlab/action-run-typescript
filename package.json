  "devDependencies": {
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-config-jaid": "^25.0.0",
    "tsconfig-jaid-bun": "^13.0.0",
    "typescript": "^6.0.2"
  }
}
